{
  "$schema": "http://json-schema.org/draft-07/schema",
  "type": "array",
  "default": [],
  "items": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string"
      },
      "type": {
        "type": "string",
        "enum": ["follow", "sub", "resub", "subgift", "bits", "raid", "channelpoints"]
      },
      "username": {
        "type": "string"
      },
      "message": {
        "type": "string"
      },
      "amount": {
        "type": "number",
        "default": 0
      },
      "tier": {
        "type": "string",
        "default": ""
      },
      "timestamp": {
        "type": "number"
      }
    },
    "required": ["id", "type", "username", "timestamp"]
  }
}
