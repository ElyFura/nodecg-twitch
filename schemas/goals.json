{
  "$schema": "http://json-schema.org/draft-07/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "followGoal": { "$ref": "#/$defs/goalConfig" },
    "subGoal": { "$ref": "#/$defs/goalConfig" },
    "bitsGoal": { "$ref": "#/$defs/goalConfig" }
  },
  "$defs": {
    "goalConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "target": {
          "type": "number",
          "default": 100,
          "minimum": 1
        },
        "current": {
          "type": "number",
          "default": 0,
          "minimum": 0
        },
        "label": {
          "type": "string",
          "default": ""
        },
        "showInOverlay": {
          "type": "boolean",
          "default": false
        },
        "barColor": {
          "type": "string",
          "default": "#6441a5"
        },
        "barBgColor": {
          "type": "string",
          "default": "#1a1a2e"
        },
        "textColor": {
          "type": "string",
          "default": "#ffffff"
        }
      }
    }
  },
  "default": {
    "followGoal": {
      "enabled": false,
      "target": 100,
      "current": 0,
      "label": "Follow-Goal",
      "showInOverlay": false,
      "barColor": "#6441a5",
      "barBgColor": "#1a1a2e",
      "textColor": "#ffffff"
    },
    "subGoal": {
      "enabled": false,
      "target": 50,
      "current": 0,
      "label": "Sub-Goal",
      "showInOverlay": false,
      "barColor": "#6441a5",
      "barBgColor": "#1a1a2e",
      "textColor": "#ffffff"
    },
    "bitsGoal": {
      "enabled": false,
      "target": 10000,
      "current": 0,
      "label": "Bits-Goal",
      "showInOverlay": false,
      "barColor": "#ff8c00",
      "barBgColor": "#1a1a2e",
      "textColor": "#ffffff"
    }
  }
}
