{
  "$schema": "http://json-schema.org/draft-07/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "follow": { "$ref": "#/$defs/alertTypeConfig" },
    "sub": { "$ref": "#/$defs/alertTypeConfig" },
    "resub": { "$ref": "#/$defs/alertTypeConfig" },
    "subgift": { "$ref": "#/$defs/alertTypeConfig" },
    "bits": { "$ref": "#/$defs/alertTypeConfig" },
    "raid": { "$ref": "#/$defs/alertTypeConfig" },
    "channelpoints": { "$ref": "#/$defs/alertTypeConfig" }
  },
  "$defs": {
    "alertTypeConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "duration": {
          "type": "number",
          "default": 5000,
          "description": "Display duration in milliseconds"
        },
        "messageTemplate": {
          "type": "string",
          "default": "{username}"
        },
        "backgroundColor": {
          "type": "string",
          "default": "#6441a5"
        },
        "textColor": {
          "type": "string",
          "default": "#ffffff"
        },
        "accentColor": {
          "type": "string",
          "default": "#b9a3e3"
        },
        "animation": {
          "type": "string",
          "enum": ["slide", "fade", "bounce"],
          "default": "slide"
        },
        "soundEnabled": {
          "type": "boolean",
          "default": true
        },
        "backgroundImage": {
          "type": "string",
          "default": ""
        },
        "position": {
          "type": "string",
          "enum": ["top-left", "top-center", "top-right", "center", "bottom-left", "bottom-center", "bottom-right"],
          "default": "bottom-center"
        },
        "iconUrl": {
          "type": "string",
          "default": ""
        },
        "fontFamily": {
          "type": "string",
          "default": ""
        },
        "fontSize": {
          "type": "number",
          "default": 24
        },
        "textShadow": {
          "type": "boolean",
          "default": false
        },
        "textShadowColor": {
          "type": "string",
          "default": "#000000"
        },
        "textOutline": {
          "type": "boolean",
          "default": false
        },
        "textOutlineColor": {
          "type": "string",
          "default": "#000000"
        },
        "overlayOpacity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.7
        },
        "animationInDuration": {
          "type": "number",
          "default": 500,
          "description": "Entrance animation duration in milliseconds"
        },
        "animationOutDuration": {
          "type": "number",
          "default": 400,
          "description": "Exit animation duration in milliseconds"
        },
        "priority": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10,
          "default": 5
        },
        "customCss": {
          "type": "string",
          "default": "",
          "description": "Custom CSS injected when this alert type is shown"
        },
        "minAmount": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Minimum amount to trigger alert (bits, viewers, months, gifts)"
        },
        "minTier": {
          "type": "string",
          "enum": ["", "1000", "2000", "3000"],
          "default": "",
          "description": "Minimum sub tier (1000=Tier1, 2000=Tier2, 3000=Tier3)"
        },
        "cooldown": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Minimum seconds between alerts of this type"
        },
        "backgroundVideo": {
          "type": "string",
          "default": "",
          "description": "URL to a video file used as background"
        },
        "ttsEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable text-to-speech for this alert type"
        },
        "ttsRate": {
          "type": "number",
          "default": 1,
          "minimum": 0.5,
          "maximum": 2,
          "description": "TTS speech rate"
        },
        "ttsVolume": {
          "type": "number",
          "default": 1,
          "minimum": 0,
          "maximum": 1,
          "description": "TTS volume"
        }
      }
    }
  },
  "default": {
    "follow": {
      "enabled": true,
      "duration": 5000,
      "messageTemplate": "{username} ist jetzt dabei!",
      "backgroundColor": "#6441a5",
