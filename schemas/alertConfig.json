      "accentColor": "#b9a3e3",
      "animation": "slide",
      "soundEnabled": true,
      "backgroundImage": "",
      "position": "bottom-center",
      "iconUrl": "",
      "fontFamily": "",
      "fontSize": 24,
      "textShadow": false,
      "textShadowColor": "#000000",
      "textOutline": false,
      "textOutlineColor": "#000000",
      "overlayOpacity": 0.7,
      "animationInDuration": 500,
      "animationOutDuration": 400,
      "priority": 3,
      "customCss": "",
