{
  "$schema": "http://json-schema.org/draft-07/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "status": {
      "type": "string",
      "enum": ["connected", "connecting", "disconnected", "error"],
      "default": "disconnected"
    },
    "message": {
      "type": "string",
      "default": ""
    }
  },
  "required": ["status"]
}
