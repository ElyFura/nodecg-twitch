{
  "$schema": "http://json-schema.org/draft-07/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "clientId": {
      "type": "string",
      "default": ""
    },
    "clientSecret": {
      "type": "string",
      "default": ""
    },
    "channelName": {
      "type": "string",
      "default": ""
    },
    "accessToken": {
      "type": "string",
      "default": ""
    },
    "refreshToken": {
      "type": "string",
      "default": ""
    },
    "userId": {
      "type": "string",
      "default": ""
    }
  },
  "required": ["clientId", "clientSecret", "channelName"]
}
