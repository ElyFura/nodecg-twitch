{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"type": "array",
	"default": [],
	"items": {
		"type": "object",
		"properties": {
			"id": {
				"type": "string"
			},
			"username": {
				"type": "string"
			},
			"displayName": {
				"type": "string"
			},
			"color": {
				"type": ["string", "null"]
			},
			"text": {
				"type": "string"
			},
			"badges": {
				"type": "object",
				"additionalProperties": {
					"type": "string"
				}
			},
			"fragments": {
				"type": "array",
				"items": {
					"type": "object",
					"properties": {
						"type": {
							"type": "string",
							"enum": ["text", "emote", "cheermote", "mention"]
						},
						"text": {
							"type": "string"
						},
						"emoteId": {
							"type": "string"
						}
					},
					"required": ["type", "text"]
				}
			},
			"timestamp": {
				"type": "number"
			}
		},
		"required": ["id", "username", "displayName", "text", "timestamp"]
	}
}
